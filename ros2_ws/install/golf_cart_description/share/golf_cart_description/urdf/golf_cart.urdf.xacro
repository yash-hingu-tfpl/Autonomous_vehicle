<?xml version="1.0"?>
<robot name="golf_cart" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===================== PARAMETERS (METERS) ===================== -->
  <xacro:property name="wheelbase" value="2.30"/>        <!-- front axle to rear axle -->
  <xacro:property name="rear_track" value="1.005"/>      <!-- distance between rear wheels -->
  <xacro:property name="wheel_radius" value="0.23"/>     <!-- 46 cm diameter -->
  <xacro:property name="wheel_width" value="0.19304"/>   <!-- 19.304 cm -->
  <xacro:property name="base_height" value="0.30"/>      <!-- chassis height -->
  <xacro:property name="base_width" value="1.20"/>

  <!-- ===================== MATERIALS ===================== -->
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <!-- ===================== BASE FOOTPRINT ===================== -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- base_link origin at chassis center -->
    <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ===================== BASE LINK ===================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${wheelbase} ${base_width} ${base_height}"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <geometry>
        <box size="${wheelbase} ${base_width} ${base_height}"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="150"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="20" iyy="40" izz="50"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ===================== WHEEL MACRO ===================== -->
  <xacro:macro name="wheel" params="name">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="10"/>
        <origin xyz="0 0 0"/>
        <inertia
          ixx="0.1" iyy="0.1" izz="0.1"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- ===================== WHEELS ===================== -->
  <xacro:wheel name="rear_left_wheel"/>
  <xacro:wheel name="rear_right_wheel"/>
  <xacro:wheel name="front_left_wheel"/>
  <xacro:wheel name="front_right_wheel"/>

  <!-- ===================== WHEEL JOINT POSITIONS ===================== -->
  <!-- wheel z = -(base_height/2 + wheel_radius) = -(0.15 + 0.23) = -0.38 -->

  <!-- REAR LEFT -->
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-1.15  0.5025 -0.38" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- REAR RIGHT -->
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-1.15 -0.5025 -0.38" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- FRONT LEFT -->
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz=" 1.15  0.5025 -0.38" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- FRONT RIGHT -->
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz=" 1.15 -0.5025 -0.38" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

</robot>
