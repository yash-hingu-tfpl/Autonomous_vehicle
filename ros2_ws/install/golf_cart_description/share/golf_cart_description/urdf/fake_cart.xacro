<?xml version="1.0"?>
<robot name="golf_cart" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================================================= -->
  <!-- PARAMETERS -->
  <!-- ================================================= -->
  <xacro:property name="wheel_radius" value="0.23"/>
  <!-- <xacro:property name="wheel_radius" value="0.15"/> -->
  <xacro:property name="wheel_width"  value="0.15"/>

  <xacro:property name="wheelbase"    value="2.30"/>
  <xacro:property name="track_width"  value="1.005"/>

  <xacro:property name="chassis_length" value="2.8"/>
  <xacro:property name="chassis_width"  value="1.2"/>
  <xacro:property name="chassis_height" value="0.2"/>
  <xacro:property name="chassis_mass"   value="300"/>

  <!-- ================================================= -->
  <!-- REALSENSE D455 -->
  <!-- ================================================= -->
  <xacro:include
    filename="$(find realsense2_description)/urdf/_d455.urdf.xacro"/>

    <!-- <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/> -->
      
  <!-- ================================================= -->
  <!-- BASE LINK -->
  <!-- ================================================= -->
    <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>
  <link name="base_link">
    <!-- <visual>
      <origin xyz="0 0 ${chassis_height/2}"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </visual> -->
    <visual>
    <origin xyz="${wheelbase/2} 0 ${chassis_height/2}"/>
    <geometry>
      <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
    </geometry>
  </visual>

    <!-- <collision>
      <origin xyz="0 0 ${chassis_height/2}"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision> -->
<collision>
    <origin xyz="${wheelbase/2} 0 ${chassis_height/2}"/>
    <geometry>
      <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
    </geometry>
  </collision>
    <inertial>
      <origin xyz="0 0 ${chassis_height/2}"/>
      <mass value="${chassis_mass}"/>
      <inertia
        ixx="80" ixy="0" ixz="0"
        iyy="160" iyz="0"
        izz="200"/>
    </inertial>
  </link>

  <!-- ================================================= -->
  <!-- REALSENSE MOUNT -->
  <!-- ================================================= -->
  <xacro:sensor_d455
    name="d455"
    parent="base_link"
    >
    <origin xyz="2.65 0.0 0.31" rpy="0 0 0"/>
  </xacro:sensor_d455>

  <!-- ================================================= -->
  <!-- WHEEL MACRO -->
  <!-- ================================================= -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_link">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="20"/>
        <inertia ixx="1" iyy="1" izz="1" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${x} ${y} 0"/> 
      <!-- here i changed -->
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ================================================= -->
  <!-- STEERED WHEEL MACRO -->
  <!-- ================================================= -->
  <xacro:macro name="steered_wheel" params="steer_name wheel_name x y">
    <link name="${steer_name}_link">
      <inertial>
        <mass value="5"/>
        <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${steer_name}_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${steer_name}_link"/>
      <origin xyz="${x} ${y} ${wheel_radius}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.523599" upper="0.523599" effort="100" velocity="1.5"/>
    </joint>

    <link name="${wheel_name}_link">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="20"/>
        <inertia ixx="1" iyy="1" izz="1" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${wheel_name}_joint" type="continuous">
      <parent link="${steer_name}_link"/>
      <child link="${wheel_name}_link"/>
      <origin xyz="0 0 -${wheel_radius}"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ================================================= -->
  <!-- REAR WHEELS -->
  <!-- ================================================= -->
  <!-- <xacro:wheel name="rear_left_wheel"
               x="-${wheelbase/2}"
               y="${track_width/2}"/>

  <xacro:wheel name="rear_right_wheel"
               x="-${wheelbase/2}"
               y="-${track_width/2}"/> -->

         <xacro:wheel name="rear_left_wheel"
             x="0"
             y="${track_width/2}"/>

<xacro:wheel name="rear_right_wheel"
             x="0"
             y="-${track_width/2}"/>      

  <!-- ================================================= -->
  <!-- FRONT STEERING WHEELS -->
  <!-- ================================================= -->
  <!-- <xacro:steered_wheel
      steer_name="front_left_steering"
      wheel_name="front_left_wheel"
      x="${wheelbase/2}"
      y="${track_width/2}"/>

  <xacro:steered_wheel
      steer_name="front_right_steering"
      wheel_name="front_right_wheel"
      x="${wheelbase/2}"
      y="-${track_width/2}"/> -->
      <xacro:steered_wheel
    steer_name="front_left_steering"
    wheel_name="front_left_wheel"
    x="${wheelbase}"
    y="${track_width/2}"/>

<xacro:steered_wheel
    steer_name="front_right_steering"
    wheel_name="front_right_wheel"
    x="${wheelbase}"
    y="-${track_width/2}"/>

  <!-- ================================================= -->
  <!-- ROS2 CONTROL  -->
  <!-- ================================================= -->
  <ros2_control name="FakeAckermannSystem" type="system">
  <hardware>
    <!-- <plugin>mock_components/GenericSystem</plugin>
     <param name="calculate_dynamics">true</param> -->
         <plugin>esp32_hardware/ESP32Hardware</plugin>
  </hardware>

  <!-- Rear wheels -->
  <joint name="rear_left_wheel_joint">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="rear_right_wheel_joint">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <!-- Front steering -->
  <joint name="front_left_steering_joint">
    <command_interface name="position">
        <param name="min">-0.6</param>
        <param name="max">0.6</param>
    </command_interface>
    <state_interface name="position"/>
  </joint>

  <joint name="front_right_steering_joint">
        <command_interface name="position">
        <param name="min">-0.6</param>
        <param name="max">0.6</param>
    </command_interface>
    <state_interface name="position"/>
  </joint>

  <!--  FRONT WHEEL ROTATION (MISSING BEFORE) -->
  <joint name="front_left_wheel_joint">
    <state_interface name="position"/>
  </joint>

  <joint name="front_right_wheel_joint">
    <state_interface name="position"/>
  </joint>
</ros2_control>


</robot>
